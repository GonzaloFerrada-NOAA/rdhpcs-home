#!/bin/bash

JOBFILE="${1:-$(basename "$PWD")}"
XMLFILE="${JOBFILE}.xml"
DBFILE="${JOBFILE}.db"

if [[ ! -f "$XMLFILE" ]]; then
  echo "Error: job XML not found: $XMLFILE" >&2
  exit 1
fi

echo $(date)
echo "rocotorun -d ${DBFILE} -w ${XMLFILE}"
/apps/rocoto/1.3.7/bin/rocotorun -d "${DBFILE}" -w "${XMLFILE}"
